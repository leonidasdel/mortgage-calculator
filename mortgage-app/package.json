{
  "name": "mortgage-app",
  "version": "1.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:coverage": "ng test --watch=false --coverage",
    "lint": "ng lint",
    "format:check": "prettier --check \"src/**/*.{ts,html,scss}\"",
    "e2e": "PLAYWRIGHT_BROWSERS_PATH=0 playwright test",
    "e2e:ui": "PLAYWRIGHT_BROWSERS_PATH=0 playwright test --ui",
    "e2e:ci": "npm run build && CI=1 PLAYWRIGHT_BROWSERS_PATH=0 playwright test",
    "ng:e2e": "ng e2e"
  },
  "private": true,
  "packageManager": "npm@10.9.4",
  "dependencies": {
    "@angular/common": "21.2.14",
    "@angular/compiler": "21.2.14",
    "@angular/core": "21.2.14",
    "@angular/forms": "21.2.14",
    "@angular/platform-browser": "21.2.14",
    "@angular/platform-server": "21.2.14",
    "@angular/router": "21.2.14",
    "@angular/service-worker": "21.2.14",
    "@angular/ssr": "21.2.12",
    "@ngrx/signals": "^21.1.0",
    "@types/express": "^5.0.6",
    "express": "^5.2.1",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "21.2.12",
    "@angular/cdk": "21.2.12",
    "@angular/cli": "21.2.12",
    "@angular/compiler-cli": "21.2.14",
    "@axe-core/playwright": "^4.10.2",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "1.60.0",
    "@vitest/coverage-v8": "^4.1.7",
    "angular-eslint": "21.4.0",
    "eslint": "^10.3.0",
    "jsdom": "^28.0.0",
    "playwright-ng-schematics": "^21.1.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2",
    "typescript-eslint": "8.59.2",
    "vitest": "^4.0.8"
  }
}
